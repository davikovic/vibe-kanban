{
  "name": "kanban-flow",
  "version": "1.0.0",
  "description": "Kanban task organizer built with Electron",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist": "electron-builder"
  },
  "dependencies": {
    "dompurify": "^3.3.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "marked": "^18.0.0"
  },
  "build": {
    "appId": "KanbanFlow.app",
    "productName": "KanbanFlow",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "author": "",
  "license": "MIT"
}
